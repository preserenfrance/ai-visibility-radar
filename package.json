{
  "name": "ai-visibility-radar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm --workspace @ai-radar/db run prisma:generate",
    "db:migrate:init": "npm --workspace @ai-radar/db exec -- prisma migrate dev --schema prisma/schema.prisma --name init",
    "db:migrate": "npm --workspace @ai-radar/db run prisma:migrate",
    "db:deploy": "npm --workspace @ai-radar/db run prisma:deploy",
    "db:push": "npm --workspace @ai-radar/db exec -- prisma db push --schema prisma/schema.prisma",
    "vercel:build": "node scripts/vercel-build.mjs",
    "worker:dev": "npm --workspace @ai-radar/worker run dev",
    "web:dev": "npm --workspace @ai-radar/web run dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "@playwright/test": "^1.49.1",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
