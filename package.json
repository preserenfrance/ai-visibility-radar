{
  "name": "ai-visibility-radar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @ai-radar/db prisma:generate",
    "db:migrate:init": "pnpm --filter @ai-radar/db exec prisma migrate dev --schema prisma/schema.prisma --name init",
    "db:migrate": "pnpm --filter @ai-radar/db prisma:migrate",
    "db:deploy": "pnpm --filter @ai-radar/db prisma:deploy",
    "vercel:build": "pnpm db:generate && turbo run build --filter=@ai-radar/web...",
    "worker:dev": "pnpm --filter @ai-radar/worker dev",
    "web:dev": "pnpm --filter @ai-radar/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "@playwright/test": "^1.49.1",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
