{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "incremental": true,
    "jsx": "preserve",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@ai-radar/ai": ["../../packages/ai/src/index.ts"],
      "@ai-radar/config": ["../../packages/config/src/index.ts"],
      "@ai-radar/crawler": ["../../packages/crawler/src/index.ts"],
      "@ai-radar/db": ["../../packages/db/src/index.ts"],
      "@ai-radar/email": ["../../packages/email/src/index.ts"],
      "@ai-radar/parser": ["../../packages/parser/src/index.ts"],
      "@ai-radar/prompts": ["../../packages/prompts/src/index.ts"],
      "@ai-radar/reports": ["../../packages/reports/src/index.ts"],
      "@ai-radar/scoring": ["../../packages/scoring/src/index.ts"],
      "@ai-radar/shared": ["../../packages/shared/src/index.ts"],
      "@ai-radar/usage": ["../../packages/usage/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
